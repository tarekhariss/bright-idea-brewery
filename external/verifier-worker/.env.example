# --- Required ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VERIFICATION_WORKER_SECRET=replace-me

# --- Worker identity ---
WORKER_ID=worker-eu-1
WORKER_VERSION=1.3.0
WORKER_HOST=eu-west-1
WORKER_REGION=eu

# --- Engine ---
VERIFIER_URL=http://email-verifier:8080
VERIFIER_ENGINE=aftership-email-verifier
VERIFIER_VERSION=1.4.1
DISABLE_SMTP_CHECK=0
SMTP_HELO_NAME=verifier.tlbg.cloud
SMTP_FROM_EMAIL=postmaster@tlbg.cloud

# --- Tuning (mode profiles override these per-job) ---
CLAIM_BATCH_SIZE=25
CLAIM_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=60000
MAX_CONCURRENCY=10
PER_DOMAIN_DELAY_MS=5000
MAX_RETRIES=3

# --- Unknown recovery loop ---
RECOVERY_INTERVAL_MS=15000
RECOVERY_CONCURRENCY=5
SMTP_HELO_POOL=
SMTP_FROM_POOL=

# --- Node-side SMTP probe ---
# Captures banner, EHLO, STARTTLS, TLS handshake on port 25.
# Runs conservatively (only on unknown/retry/high-accuracy), per-MX rate
# limited. Set to 0 on hosts where port 25 is blocked outbound.
SMTP_PROBE_ENABLED=1
SMTP_PROBE_HELO=verifier.tlbg.cloud
SMTP_PROBE_FROM=postmaster@tlbg.cloud

# --- Optional: SMTP egress proxy ---
PROXY_URL=
