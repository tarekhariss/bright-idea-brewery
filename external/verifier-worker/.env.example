# --- Required ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VERIFICATION_WORKER_SECRET=replace-me

# --- Worker identity ---
WORKER_ID=worker-eu-1
WORKER_VERSION=1.0.0
WORKER_HOST=eu-west-1
WORKER_REGION=eu

# --- Engine ---
# Default: locally-built engine service from ./engine (AfterShip
# email-verifier Go library, MIT). On Railway, set this to the internal
# URL of the engine service, e.g. http://email-verifier.railway.internal:8080
VERIFIER_URL=http://email-verifier:8080
VERIFIER_ENGINE=aftership-email-verifier
VERIFIER_VERSION=1.4.1
# Set to 1 on hosts that block outbound port 25 (Railway, Render, Fly free).
DISABLE_SMTP_CHECK=1
SMTP_HELO_NAME=
SMTP_FROM_EMAIL=

# --- Tuning ---
CLAIM_BATCH_SIZE=50
CLAIM_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=60000
MAX_CONCURRENCY=10
PER_DOMAIN_DELAY_MS=5000
MAX_RETRIES=3

# --- Optional: SMTP egress proxy ---
PROXY_URL=
